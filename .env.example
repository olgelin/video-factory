# Video Factory Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API (Required)
# =============================================================================
# Primary API key for script writing, storyboard, design system, etc.
VF_API_KEY=your_api_key_here
VF_API_BASE_URL=https://api.openai.com/v1
VF_MODEL=gpt-4o

# Fallback API (optional, used when primary fails)
VF_FALLBACK_KEY=
VF_FALLBACK_URL=
VF_FALLBACK_MODEL=

# =============================================================================
# Voice Generation
# =============================================================================
# VoxCPM model path (local GPU inference)
VOICE_MODEL_PATH=E:/Hermes-Agent/workspace/xiaoshan/models/VoxCPM2
# Reference voice for cloning
REFERENCE_VOICE=reference_voice.wav
# Default speed (1.0 = normal, 1.2 = 20% faster)
VOICE_SPEED=1.2

# =============================================================================
# BGM Generation
# =============================================================================
# ACE-Step model path (local GPU inference)
BGM_MODEL_PATH=E:/Hermes-Agent/workspace/xiaoshan/models/ace-step
# BGM duration in seconds (default: 210 = 3min 30sec)
BGM_DURATION=210

# =============================================================================
# Transcription
# =============================================================================
# Whisper model size (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# =============================================================================
# Video Output
# =============================================================================
# Resolution (default: 1920x1080)
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
