# =============================================================================
# Video Factory Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Place .env in one of these locations (checked in order):
#   1. $HERMES_HOME/.env
#   2. ~/.hermes/.env
#   3. ~/.env
#
# llm_utils.load_env() is called once at import time; individual skills
# do NOT need to call load_env() themselves.

# =============================================================================
# LLM Provider
# =============================================================================
# Primary LLM key (Xiaomi MiMo / OpenAI-compatible)
XIAOMI_API_KEY=your_xiaomi_api_key_here

# Optional: override default LLM endpoint/model
# VF_API_KEY=your_key_here
# VF_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# VF_MODEL=mimo-v2.5-pro

# Optional: fallback LLM (uncomment all three to enable)
# VF_FALLBACK_KEY=your_fallback_key
# VF_FALLBACK_BASE_URL=https://api.deepseek.com/v1
# VF_FALLBACK_MODEL=deepseek-chat

# =============================================================================
# Paths
# =============================================================================
# Hermes home directory (where .env and config live)
# Default: ~/.hermes  (or C:\Users\<user>\.hermes on Windows)
# HERMES_HOME=C:\Users\Administrator\.hermes

# Models directory (parent of acestep_package, voxcpm, etc.)
# Default: derived from ACESTEP_ROOT parent directory
# MODELS_DIR=E:/Hermes-Agent/workspace/xiaoshan/models

# =============================================================================
# ACE-Step (BGM Generator)
# =============================================================================
# Root of the acestep_package installation
ACESTEP_ROOT=E:/Hermes-Agent/workspace/xiaoshan/models/acestep_package

# Checkpoint name (inside ACESTEP_ROOT)
# ACESTEP_CHECKPOINT=acestep-v15-turbo

# =============================================================================
# VoxCPM2 (Voice Generator)
# =============================================================================
# Path to VoxCPM2 model snapshot directory
VOXCPM_MODEL=E:/Hermes-Agent/workspace/xiaoshan/models/models--openbmb--VoxCPM2/snapshots/bffb3df5a29440629464e5e839f4d214c8714c3d

# Path to reference voice WAV (for voice cloning)
VOICE_REF_WAV=E:/Hermes-Agent/workspace/xiaoshan/video-factory/hf-project/assets/reference_voice.wav
