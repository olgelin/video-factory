prefix=D:/Repos/video2x/build/video2x-install
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/.

Name: libspdlog
Description: Fast C++ logging library.
URL: https://github.com/gabime/spdlog
Version: 1.15.0
CFlags: -I${includedir} -DSPDLOG_SHARED_LIB -DFMT_SHARED -DSPDLOG_COMPILED_LIB -DSPDLOG_NO_EXCEPTIONS -DFMT_EXCEPTIONS=0
Libs: -L${libdir} -lspdlog -pthread
Requires: 

